# ── APP ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="Omzone"
VITE_APP_ENV=development
VITE_APP_BASE_URL=http://localhost:5173
VITE_APP_VERSION=1.0.0
VITE_DEFAULT_LOCALE=es
VITE_DEFAULT_CURRENCY=MXN

# ── APPWRITE ─────────────────────────────────────────────────────────────────
VITE_APPWRITE_ENDPOINT=https://appwrite.racoondevs.com/v1
VITE_APPWRITE_PROJECT_ID=69b37e1f001cce5d19cc
VITE_APPWRITE_DATABASE_ID=main
# The public URL used as redirect base for email verification links
VITE_APPWRITE_APP_URL=https://omzone.com

# ── Collections ──────────────────────────────────────────────────────────────
VITE_APPWRITE_COLLECTION_USERS_PROFILE_ID=users_profile
VITE_APPWRITE_COLLECTION_CONTACT_LEADS_ID=contact_leads
VITE_APPWRITE_COLLECTION_INSTRUCTORS_ID=instructors
VITE_APPWRITE_COLLECTION_CLASS_TYPES_ID=class_types
VITE_APPWRITE_COLLECTION_CLASSES_ID=classes
VITE_APPWRITE_COLLECTION_CLASS_SESSIONS_ID=class_sessions
VITE_APPWRITE_COLLECTION_WELLNESS_PRODUCTS_ID=wellness_products
VITE_APPWRITE_COLLECTION_WELLNESS_PACKAGES_ID=wellness_packages
VITE_APPWRITE_COLLECTION_ORDERS_ID=orders
VITE_APPWRITE_COLLECTION_ORDER_ITEMS_ID=order_items
VITE_APPWRITE_COLLECTION_PAYMENTS_ID=payments
VITE_APPWRITE_COLLECTION_BOOKINGS_ID=bookings
VITE_APPWRITE_COLLECTION_CLIENT_PACKAGES_ID=client_packages
VITE_APPWRITE_COLLECTION_PACKAGE_USAGES_ID=package_usages
VITE_APPWRITE_COLLECTION_ACCESS_PASSES_ID=access_passes
VITE_APPWRITE_COLLECTION_SITE_CONTENT_ID=site_content
VITE_APPWRITE_COLLECTION_AUDIT_LOGS_ID=audit_logs
VITE_APPWRITE_COLLECTION_APP_SETTINGS_ID=app_settings

# ── Buckets ──────────────────────────────────────────────────────────────────
VITE_APPWRITE_BUCKET_PUBLIC_MEDIA_ID=public-media
VITE_APPWRITE_BUCKET_PRIVATE_MEDIA_ID=private-media

# ── Functions ────────────────────────────────────────────────────────────────
# IDs assigned by Appwrite after deploying each function (appwrite deploy function)
VITE_APPWRITE_FUNCTION_CREATE_USER_PROFILE_ID=
VITE_APPWRITE_FUNCTION_SYNC_USER_PROFILE_ID=
VITE_APPWRITE_FUNCTION_SYNC_EMAIL_VERIFICATION_ID=

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to use mock services instead of real Appwrite (local dev)
VITE_USE_MOCKS=true

# =============================================================================
# SERVER-SIDE / FUNCTIONS VARIABLES (NOT for frontend — keep in .env only)
# These are set as environment variables in each Appwrite Function via CLI or UI
# =============================================================================
# APPWRITE_ENDPOINT=https://appwrite.racoondevs.com/v1
# APPWRITE_PROJECT_ID=
# APPWRITE_API_KEY=            # Server API key with users.read, users.write, databases.read, databases.write
# APPWRITE_DATABASE_ID=main
# APPWRITE_USERS_PROFILE_COLLECTION_ID=users_profile
