# sync-user-profile — Variables de entorno
# Mismo nombre de vars que el frontend (.env del proyecto).
# Configurar en Appwrite Console → Global Variables (aplica a todas las functions).

# ── Shared con frontend ────────────────────────────────────────────────────────
APPWRITE_ENDPOINT=https://appwrite.racoondevs.com/v1
APPWRITE_PROJECT_ID=69b37e1f001cce5d19cc
APPWRITE_DATABASE_ID=main
APPWRITE_COLLECTION_USERS_PROFILE_ID=users_profile

# ── Server secret — NUNCA en frontend ni en repositorio ───────────────────────
# Crear en: Appwrite Console → Settings → API Keys
# Scopes mínimos: users.read, users.write, databases.read, databases.write
APPWRITE_API_KEY=
